<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#111111">

    <androidx.camera.view.PreviewView
        android:id="@+id/previewView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:implementationMode="performance"
        app:scaleType="fillCenter" />

    <com.birdie.camera.RoiOverlayView
        android:id="@+id/roiOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:id="@+id/controlPanel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:padding="12dp"
        android:background="#DD111111">

        <TextView
            android:id="@+id/statusText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Starting Birdie"
            android:textColor="#F4F4F0"
            android:textSize="14sp" />

        <TextView
            android:id="@+id/debugStatsText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="monospace"
            android:text="motion --"
            android:textColor="#C8D7C2"
            android:textSize="12sp" />

        <EditText
            android:id="@+id/backendUrlInput"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:hint="Backend URL"
            android:inputType="textUri"
            android:singleLine="true"
            android:textColor="#F4F4F0"
            android:textColorHint="#A8A8A0"
            android:backgroundTint="#D8D8D0" />

        <EditText
            android:id="@+id/deviceTokenInput"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:hint="Device token"
            android:inputType="textPassword"
            android:singleLine="true"
            android:textColor="#F4F4F0"
            android:textColorHint="#A8A8A0"
            android:backgroundTint="#D8D8D0" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:gravity="end"
            android:orientation="horizontal">

            <Button
                android:id="@+id/statusButton"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:text="Status" />

            <Button
                android:id="@+id/retryButton"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:layout_marginStart="8dp"
                android:text="Retry" />
        </LinearLayout>
    </LinearLayout>

</FrameLayout>
